import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        long n = sc.nextLong();
        long m = sc.nextLong();
        long a = sc.nextLong();

        long x = (n + a - 1) / a; // Ceiling of n/a
        long y = (m + a - 1) / a; // Ceiling of m/a

        System.out.println(x * y);
    }
}
